# Environment Variables Template
# Copy this to .env and fill in your values

# Server Port
PORT=5000

# MongoDB Connection String
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/taskrix

# For MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taskrix

# JWT Secret Key (change this in production!)
# Generate a strong secret: https://www.random.org/ or use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Node Environment
NODE_ENV=development
# Set to 'production' when deploying

# Frontend URL (for CORS if needed)
# FRONTEND_URL=http://localhost:3000

# Debugging
# DEBUG=app:*
